{
  "compilerOptions": {
    "lib": ["ES2015", "ES2016", "ES2017" , "DOM"],
    "esModuleInterop": true,
    "baseUrl": "./types",
    "strict": true,
    "outDir": "lib",
    "typeRoots": ["./node_modules/@types" , "./types"],
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "node",
    "skipLibCheck": true,
  },
  "include": ["test"],
  "exclude": ["node_modules"]
}
