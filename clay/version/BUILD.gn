import("../common/config.gni")
import("version.gni")

# Use a version.inc file instead of defining macors in the source set
# since on Android, after gn to cmake process, the belowing macros may leak
# to other sources files and result in recompile.
action("version_inc") {
  script = "write_file.py"

  args = [
    "--output",
    rebase_path("$root_gen_dir/clay/version/version.inc"),
    "--content",
    string_join("\n",
                [
                  "// Generated by clay/version:version_inc",
                  "#define ENGINE_VERSION \"$engine_version\"",
                  "#define SKIA_VERSION \"$skia_version\"",
                  "#define CLAY_BUILD_VERSION \"$build_version\"",
                  "#define CLAY_BUILD_NUMBER $build_number",
                  "",
                ]),
  ]

  outputs = [ "$root_gen_dir/clay/version/version.inc" ]
}

source_set("version") {
  sources = [
    "version.cc",
    "version.h",
  ]

  public_configs = [ "../:config" ]

  deps = [
    ":version_inc",
    "../fml:fml",
  ]
}
